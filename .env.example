# Application Environment
NODE_ENV=production

# API Configuration
# For GitHub Pages: Leave empty or use external API endpoint
# For local development: Use http://localhost:3000 if backend is running
VITE_API_URL=http://localhost:3000

# Use mock API for demo/testing (no backend required)
# Set to true to use mock data instead of real API
VITE_USE_MOCK_API=false

# Database (for backend only, not needed for GitHub Pages frontend)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# CORS Configuration (backend only)
CORS_ORIGIN=http://localhost:5173

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_BETA_FEATURES=false

# Deployment-specific
# For Vercel:
# - Set VITE_API_URL to your Vercel backend domain
# - Set VITE_USE_MOCK_API=false to use real API
# - Add these in Vercel Dashboard > Settings > Environment Variables

# For GitHub Pages (static only):
# - Leave VITE_API_URL empty for relative API calls
# - Or set to external API endpoint
# - Set VITE_USE_MOCK_API=true for demo without backend
# - Or set up a mock API service elsewhere

# Local Development:
# - Copy to .env.local
# - Uncomment and configure as needed
# - .env.local is ignored by git
