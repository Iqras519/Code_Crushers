# Local Development Environment Configuration
# Copy this to .env.local and customize for your setup
# This file is ignored by git (.gitignore)

# ==============================================================================
# Development Settings
# ==============================================================================

NODE_ENV=development

# ==============================================================================
# API Configuration
# ==============================================================================

# Point to your local backend API
# If backend is running on localhost:3000, use this:
VITE_API_URL=http://localhost:3000

# For testing with mock data (no backend required):
# VITE_API_URL=
# VITE_USE_MOCK_API=true

# ==============================================================================
# Feature Flags
# ==============================================================================

VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_BETA_FEATURES=false

# ==============================================================================
# GitHub Pages Configuration
# ==============================================================================

# When deploying to GitHub Pages, the workflow will override these:
# - NODE_ENV: production
# - BASE_PATH: /Code_Crushers/ (or your repo name)
# - VITE_API_URL: (empty or your API endpoint)
# - VITE_USE_MOCK_API: false

# ==============================================================================
# Setup Instructions
# ==============================================================================

# 1. Start the backend API (optional):
#    cd artifacts/api-server
#    npm run dev
#    # Runs on http://localhost:3000

# 2. Start the frontend development server:
#    cd artifacts/struturacheck
#    PORT=5173 BASE_PATH=/ npm run dev
#    # Runs on http://localhost:5173

# 3. Login with demo credentials:
#    Email: demo@example.com
#    Password: password123

# ==============================================================================
# Notes
# ==============================================================================

# - This file is NOT committed to git (see .gitignore)
# - Each developer can have their own configuration
# - For CI/CD, environment variables are set in:
#   - GitHub Actions workflow (.github/workflows/deploy-github-pages.yml)
#   - Vercel project settings
